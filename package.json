{
  "name": "summative-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env concurrently --names \"TSC,VITE\" --prefix-colors \"blue.bold,magenta.bold\" \"npm run type-check\" \"npm run vite\"",
    "vite": "vite --config vite.config.ts",
    "type-check": "tsc --noEmit --watch --preserveWatchOutput",
    "biome": "biome check . --error-on-warnings",
    "cspell": "cspell . --no-progress",
    "format": "biome check --write --unsafe ."
  },
  "dependencies": {
    "axios": "^1.16.0",
    "firebase": "^12.12.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "2.4.14",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.4",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "cspell": "^10.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.3",
    "vite": "^8.0.10"
  }
}
